{
  "name": "multi-strategy-rate-limiter",
  "version": "1.0.0",
  "description": "Framework-agnostic rate limiting middleware for Express and Hono with fixed-window, sliding-window, and token-bucket strategies.",
  "type": "module",
  "main": "dist/index.cjs",
  "module": "dist/index.js",
  "types": "src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist",
    "src",
    "scripts",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "node scripts/build.mjs",
    "test": "node tests/rate-limiter.test.mjs",
    "verify": "npm run build && npm test"
  },
  "keywords": [
    "rate-limit",
    "express",
    "hono",
    "middleware",
    "redis",
    "token-bucket",
    "sliding-window",
    "fixed-window"
  ],
  "license": "MIT",
  "devDependencies": {
    "esbuild": "^0.27.3"
  }
}
